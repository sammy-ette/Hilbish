			"tags": {
				"example": [
					{
						"id": "",
						"fields": [
							"-- an extremely simple completer for sudo.",
							"hilbish.completions.add('command.sudo', function(query, ctx, fields)",
							"\ttable.remove(fields, 1)",
							"\tif #fields[1] then",
							"\t\t-- return commands because sudo runs a command as root..!",
							"",
							"\t\tlocal entries, pfx = hilbish.completions.bins(query, ctx, fields)",
							"\t\treturn {",
							"\t\t\ttype = 'grid',",
							"\t\t\titems = entries",
							"\t\t}, pfx",
							"\tend",
							"",
							"\t-- ... else suggest files or anything else ..",
							"end)"
						],
						"startIdx": 8

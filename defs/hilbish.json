				{
					"Name": "streams",
					"Type": "table|boolean",
					"Doc": null
				}
			],
			"tags": {
				"example": [
					{
						"id": "",
						"fields": [
							"-- This code is the same as `ls -l | wc -l`",
							"local fs = require 'fs'",
							"local pr, pw = fs.pipe()",
							"hilbish.run('ls -l', {",
							"\tstdout = pw,",
							"\tstderr = pw,",
							"})",
							"pw:close()",
							"hilbish.run('wc -l', {",
							"\tstdin = pr",
							"})"
						],
						"startIdx": 0
					}
				]
			}
		},
